{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"declaration": true,
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"outDir": "dist",
		"rootDir": ".",
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["bin/**/*.ts", "lib/**/*.ts"]
}
